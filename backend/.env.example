# DigitalAfrika — Backend API REST
# Copiez ce fichier en .env et remplissez les valeurs

PORT=3001
JWT_SECRET=CHANGEZ_MOI_avec_une_clé_aléatoire_de_64_caractères
JWT_EXPIRES_IN=8h

# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=votre_mot_de_passe
PGDATABASE=digitalafrika

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
